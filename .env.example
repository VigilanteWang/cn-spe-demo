# Shared template for all environments.
# Use .env.development.local and .env.production.local for actual local runs.

# === 云环境配置 ===
# 支持: global (商业版, 默认) | china (世纪互联 / 21Vianet)
# 设置后将自动推导 AAD 认证地址与 Microsoft Graph API 地址
#
# 预定义端点：
#   global → AAD: https://login.microsoftonline.com  | Graph: https://graph.microsoft.com
#   china  → AAD: https://login.chinacloudapi.cn     | Graph: https://microsoftgraph.chinacloudapi.cn
CLOUD_ENV=global
REACT_APP_CLOUD_ENV=$CLOUD_ENV

# === 后端 API 配置（私有，仅服务端使用）===
API_ENTRA_APP_CLIENT_ID=<your-api-entra-app-client-id>
API_ENTRA_APP_CLIENT_SECRET=<your-api-entra-app-client-secret>
API_ENTRA_APP_TENANT_ID=<your-tenant-id>

# AAD Authority — 由 CLOUD_ENV + API_ENTRA_APP_TENANT_ID 自动推导，无需手动填写。
# 如需覆盖（优先于云枚举推导），可取消注释：
# API_ENTRA_APP_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>/   # global
# API_ENTRA_APP_AUTHORITY=https://login.chinacloudapi.cn/<your-tenant-id>/      # china

# Microsoft Graph base URL — 由 CLOUD_ENV 自动推导，无需手动填写。
# 如需覆盖（优先于云枚举推导），可取消注释：
# GRAPH_BASE_URL=https://graph.microsoft.com               # global
# GRAPH_BASE_URL=https://microsoftgraph.chinacloudapi.cn   # china

CONTAINER_TYPE_ID=<your-container-type-id>

# === 前端配置（通过 react-scripts 构建时注入，要符合CRA规范）===
REACT_APP_CLIENT_ENTRA_APP_CLIENT_ID=<your-client-entra-app-client-id>
REACT_APP_CLIENT_ENTRA_APP_TENANT_ID=$API_ENTRA_APP_TENANT_ID
REACT_APP_API_ENTRA_APP_CLIENT_ID=$API_ENTRA_APP_CLIENT_ID
REACT_APP_API_SERVER_URL=http://localhost:3001

# REACT_APP_GRAPH_BASE_URL=$GRAPH_BASE_URL