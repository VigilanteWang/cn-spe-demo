# Production-local simulation template
# Copy to .env.production.local and fill real values.
# VITE_ prefix is required for all variables exposed to the browser bundle (Vite rule).
# Backend-only variables (API_ENTRA_APP_*, CONTAINER_TYPE_ID, CORS_ALLOWED_ORIGINS) do NOT need VITE_ prefix.

CLOUD_ENV=global
VITE_CLOUD_ENV=$CLOUD_ENV

API_ENTRA_APP_CLIENT_ID=<your-api-entra-app-client-id>
API_ENTRA_APP_CLIENT_SECRET=<your-api-entra-app-client-secret>
API_ENTRA_APP_TENANT_ID=<your-tenant-id>
CONTAINER_TYPE_ID=<your-container-type-id>

# CORS whitelist: comma-separated list of allowed frontend origins.
# For production, replace with your actual frontend domain.
CORS_ALLOWED_ORIGINS=https://your-production-domain.com

VITE_CLIENT_ENTRA_APP_CLIENT_ID=<your-client-entra-app-client-id>
VITE_CLIENT_ENTRA_APP_TENANT_ID=$API_ENTRA_APP_TENANT_ID
VITE_API_ENTRA_APP_CLIENT_ID=$API_ENTRA_APP_CLIENT_ID
VITE_API_SERVER_URL=https://your-api-server-url
